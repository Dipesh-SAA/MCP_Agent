LLM_PROVIDER="openai"

# MISTRAL_API_KEY=""
OPENAI_API_KEY=""
MISTRAL_API_KEY=""

# Comma-separated frontend origins. Use "null" when opening frontend/chat-frontend.html directly from disk.
CORS_ALLOW_ORIGINS="null"
CORS_ALLOW_ORIGIN_REGEX="^https?://(localhost|127\.0\.0\.1)(:\d+)?$"

# A2 MCP/Vibe executor chat endpoint.
A2_CHAT_URL="http://localhost:8000/api/chat"
A2_TIMEOUT_SECONDS="120"
